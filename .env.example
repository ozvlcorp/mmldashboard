# Ключ Anthropic для ИИ-консультанта.
# Получить: https://console.anthropic.com → API Keys.
# Если НЕ задать — ИИ всё равно работает, но каждый клиент вводит свой ключ
# в браузере (он хранится только локально). С заданным ключом расходы на вас.
ANTHROPIC_API_KEY=

# (необязательно) Переопределить модель. По умолчанию claude-opus-4-8.
# Дешевле/быстрее: claude-sonnet-4-6 или claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-opus-4-8

# МойСклад Vendor App credentials (нужны только при публикации в каталог)
MOYSKLAD_APP_UID=your-app-uid
MOYSKLAD_SECRET_KEY=your-secret-key

# Public app URL (для редиректа от МойСклад в виджет при публикации)
NEXT_PUBLIC_APP_URL=https://your-domain.com
